PORT=3010

# Root folder for staged ingest media. Clips are listed from:
#   <INGEST_MEDIA_ROOT>/spravy/<rundownId>/clips/
INGEST_MEDIA_ROOT=../ingest

# Base URL for GFX preview iframe templates (served at /demo-assets by default)
PREVIEW_BASE_URL=http://localhost:3010/demo-assets

# Set to false when serving over plain HTTP (e.g. internal LAN) so session cookies work.
# Defaults to true in production (NODE_ENV=production), false otherwise.
# SESSION_COOKIE_SECURE=false
