PORT=3010

# Root folder for staged ingest media. The media picker lists files from:
#   <INGEST_MEDIA_ROOT>/spravy/<rundownId>/clips/
# This mirrors the Caspar/Package Manager path layout used by sofie-demo-blueprints.
# Copy clips into that folder (not only into Caspar media) for the picker to see them.
# Can be overridden per-install in Settings → Connection → Ingest media root folder.
INGEST_MEDIA_ROOT=../ingest

# Base URL for GFX preview iframe templates (served at /demo-assets by default).
# Can be overridden per-install in Settings → Connection → GFX preview base URL.
# Production: point at `yarn serve` from demo-assets or your deployed template host.
PREVIEW_BASE_URL=http://localhost:3010/demo-assets

# Set to false when serving over plain HTTP (e.g. internal LAN) so session cookies work.
# Defaults to true in production (NODE_ENV=production), false otherwise.
# SESSION_COOKIE_SECURE=false
